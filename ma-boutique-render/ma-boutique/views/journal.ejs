<% layout('layout') -%>
<% var currentPath = '/journal'; %>

<h1 class="page-title"><i class="fas fa-clipboard-list"></i> Journal d'activité</h1>

<div class="card" style="max-width:800px;">
  <div class="card-header">
    <span class="card-title"><i class="fas fa-filter"></i> Filtres</span>
    <a href="/journal/export" class="btn btn-sm btn-outline"><i class="fas fa-download"></i> Export CSV</a>
  </div>
  <form method="GET" action="/journal">
    <div class="d-flex gap-2 flex-wrap align-center">
      <select name="user_id" class="form-select" style="max-width:200px;" onchange="this.form.submit()">
        <option value="">Tous les utilisateurs</option>
        <% users.forEach(u => { %>
        <option value="<%= u.id %>" <%= filters.user_id == u.id ? 'selected' : '' %>><%= u.email %></option>
        <% }) %>
      </select>
      <input type="text" name="action" class="form-control" placeholder="Action..." value="<%= filters.action || '' %>" style="max-width:180px;">
      <input type="date" name="debut" class="form-control" value="<%= filters.debut || '' %>" style="max-width:150px;">
      <input type="date" name="fin" class="form-control" value="<%= filters.fin || '' %>" style="max-width:150px;">
      <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-search"></i></button>
      <a href="/journal" class="btn btn-outline btn-sm"><i class="fas fa-undo"></i></a>
    </div>
  </form>
</div>

<div class="card">
  <div class="table-wrapper">
    <table class="table">
      <thead>
        <tr><th>Date</th><th>Utilisateur</th><th>Action</th><th>Détail</th></tr>
      </thead>
      <tbody>
        <% logs.forEach(l => { %>
        <tr>
          <td><%= new Date(l.created_at).toLocaleString('fr-FR') %></td>
          <td><strong><%= l.user_email || 'Système' %></strong></td>
          <td>
            <span class="badge badge-info"><i class="fas fa-tag"></i> <%= l.action %></span>
          </td>
          <td><%= l.description || '—' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% if (logs.length === 0) { %>
    <p class="text-center" style="color:#777;padding:2rem;">Aucune entrée dans le journal.</p>
  <% } %>
</div>
