<% layout('layout') -%>
<% var currentPath = '/historique-caisse'; %>

<h1 class="page-title"><i class="fas fa-history"></i> Historique de la caisse</h1>

<div class="card">
  <div class="table-wrapper">
    <table class="table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Type</th>
          <th>Montant</th>
          <th>Motif</th>
          <th>Vente liée</th>
          <th>Clôture</th>
          <th>Commentaire</th>
          <th>Utilisateur</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(r => { %>
        <tr>
          <td><%= new Date(r.date_mouvement).toLocaleString('fr-FR') %></td>
          <td>
            <span class="badge badge-<%= r.type === 'entree' ? 'success' : 'danger' %>">
              <i class="fas fa-arrow-<%= r.type === 'entree' ? 'down' : 'up' %>"></i> <%= r.type %>
            </span>
          </td>
          <td><strong><%= r.montant.toLocaleString('fr-FR') %> FCFA</strong></td>
          <td><%= r.motif %></td>
          <td><%= r.est_lie_vente ? 'Oui #' + r.vente_id : '—' %></td>
          <td><%= r.est_cloture ? '<span class="badge badge-warning">Auto</span>' : '—' %></td>
          <td><%= r.commentaire || '—' %></td>
          <td><%= r.user_email || '—' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% if (rows.length === 0) { %>
    <p class="text-center" style="color:#777;padding:2rem;">Aucun mouvement enregistré.</p>
  <% } %>
</div>
