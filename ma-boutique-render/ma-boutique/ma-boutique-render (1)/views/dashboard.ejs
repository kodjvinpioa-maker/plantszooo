<% layout('layout') -%>
<% var currentPath = '/dashboard'; %>

<h1 class="page-title"><i class="fas fa-leaf"></i> Tableau de bord</h1>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon"><i class="fas fa-coins"></i></div>
    <div class="stat-value"><%= caJour.toLocaleString('fr-FR') %> FCFA</div>
    <div class="stat-label">CA Aujourd'hui</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon"><i class="fas fa-shopping-cart"></i></div>
    <div class="stat-value"><%= totalVentes %></div>
    <div class="stat-label">Ventes totales</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon"><i class="fas fa-wallet"></i></div>
    <div class="stat-value"><%= solde.toLocaleString('fr-FR') %> FCFA</div>
    <div class="stat-label">Solde caisse</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon"><i class="fas fa-boxes"></i></div>
    <div class="stat-value"><%= produits.length %></div>
    <div class="stat-label">Produits actifs</div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <span class="card-title"><i class="fas fa-exclamation-triangle"></i> Alertes stock</span>
    <a href="/stock" class="btn btn-sm btn-outline">Gérer le stock</a>
  </div>
  <% const alertes = produits.filter(p => p.alerte); %>
  <% if (alertes.length === 0) { %>
    <p style="color:#777;"><i class="fas fa-check-circle" style="color:var(--vert-succes);"></i> Aucune alerte, tout va bien !</p>
  <% } else { %>
    <div class="table-wrapper">
      <table class="table">
        <thead>
          <tr><th>Produit</th><th>Réf.</th><th>Stock</th><th>Seuil</th><th>Action</th></tr>
        </thead>
        <tbody>
          <% alertes.forEach(p => { %>
          <tr>
            <td><strong><%= p.nom %></strong></td>
            <td><%= p.reference %></td>
            <td><span class="badge badge-danger"><%= p.stock %></span></td>
            <td><%= p.seuil_alerte %></td>
            <td><a href="/stock" class="btn btn-sm btn-primary">Réappro.</a></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<div class="card">
  <div class="card-header">
    <span class="card-title"><i class="fas fa-boxes"></i> Tous les produits</span>
    <% if (user.role === 'admin') { %>
    <a href="/produits/nouveau" class="btn btn-sm btn-primary"><i class="fas fa-plus"></i> Nouveau</a>
    <% } %>
  </div>
  <div class="table-wrapper">
    <table class="table">
      <thead>
        <tr><th>Photo</th><th>Nom</th><th>Réf.</th><th>Stock</th><th>Prix vente</th><th>Statut</th></tr>
      </thead>
      <tbody>
        <% produits.forEach(p => { %>
        <tr>
          <td>
            <% if (p.image) { %>
              <img src="<%= p.image %>" class="product-img" alt="<%= p.nom %>">
            <% } else { %>
              <div class="product-img" style="display:flex;align-items:center;justify-content:center;background:#eee;color:#999;"><i class="fas fa-image"></i></div>
            <% } %>
          </td>
          <td><strong><%= p.nom %></strong></td>
          <td><%= p.reference %></td>
          <td>
            <% if (p.alerte) { %>
              <span class="badge badge-danger"><i class="fas fa-exclamation-circle"></i> <%= p.stock %></span>
            <% } else { %>
              <span class="badge badge-success"><%= p.stock %></span>
            <% } %>
          </td>
          <td><%= p.prix_vente.toLocaleString('fr-FR') %> FCFA</td>
          <td><%= p.actif ? 'Actif' : 'Inactif' %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
