<% layout('layout') -%>
<% var currentPath = '/vente'; %>

<h1 class="page-title"><i class="fas fa-coins"></i> Nouvelle vente</h1>

<div class="card" style="max-width:600px;">
  <form method="POST" action="/vente" id="venteForm">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="form-group">
      <label class="form-label">Produit *</label>
      <input type="text" id="produitSearch" class="form-control" placeholder="Tapez pour chercher un produit..." autocomplete="off">
      <input type="hidden" name="produit_id" id="produitId" required>
      <div id="produitResults" style="position:relative;">
        <div id="produitDropdown" style="display:none;position:absolute;top:100%;left:0;right:0;background:white;border:2px solid var(--vert-clair);border-radius:12px;max-height:250px;overflow-y:auto;z-index:100;box-shadow:0 8px 25px var(--ombre-forte);"></div>
      </div>
      <div id="produitSelected" class="mt-2" style="display:none;padding:0.8rem;background:rgba(124,179,66,0.08);border-radius:10px;">
        <strong id="selectedName"></strong> — Stock: <span id="selectedStock"></span> — Prix: <span id="selectedPrice"></span> FCFA
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Quantité *</label>
        <input type="number" name="quantite" class="form-control" min="1" value="1" required>
      </div>
      <div class="form-group">
        <label class="form-label">Prix vente effectif (FCFA)</label>
        <input type="number" name="prix_vente_effectif" id="prixVenteEffectif" class="form-control" min="0" step="1">
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">Date</label>
      <input type="datetime-local" name="date_mouvement" class="form-control">
    </div>

    <div class="form-group">
      <label class="form-label">Commentaire</label>
      <textarea name="commentaire" class="form-control" rows="2" placeholder="Optionnel..."></textarea>
    </div>

    <button type="submit" class="btn btn-success btn-block"><i class="fas fa-check-circle"></i> Valider la vente</button>
  </form>
</div>

<script>
  const produits = <%- JSON.stringify(produits) %>;
  const searchInput = document.getElementById('produitSearch');
  const dropdown = document.getElementById('produitDropdown');
  const produitIdInput = document.getElementById('produitId');
  const selectedDiv = document.getElementById('produitSelected');
  const prixInput = document.getElementById('prixVenteEffectif');

  searchInput.addEventListener('input', (e) => {
    const q = e.target.value.toLowerCase().trim();
    if (!q) { dropdown.style.display = 'none'; return; }
    const matches = produits.filter(p => p.nom.toLowerCase().includes(q) || p.reference.toLowerCase().includes(q));
    if (matches.length === 0) { dropdown.style.display = 'none'; return; }
    dropdown.innerHTML = matches.map(p => `
      <div class="produit-item" data-id="${p.id}" data-nom="${p.nom}" data-stock="${p.stock}" data-prix="${p.prix_vente}"
        style="padding:0.7rem 1rem;cursor:pointer;border-bottom:1px solid rgba(0,0,0,0.05);transition:background 0.2s;"
        onmouseover="this.style.background='rgba(124,179,66,0.1)'" onmouseout="this.style.background='white'">
        <strong>${p.nom}</strong> <span style="color:#777;font-size:0.85rem;">(${p.reference})</span>
        <span style="float:right;font-size:0.85rem;">Stock: ${p.stock} — ${p.prix_vente} FCFA</span>
      </div>
    `).join('');
    dropdown.style.display = 'block';

    dropdown.querySelectorAll('.produit-item').forEach(item => {
      item.addEventListener('click', () => {
        produitIdInput.value = item.dataset.id;
        searchInput.value = item.dataset.nom;
        document.getElementById('selectedName').textContent = item.dataset.nom;
        document.getElementById('selectedStock').textContent = item.dataset.stock;
        document.getElementById('selectedPrice').textContent = item.dataset.prix;
        prixInput.value = item.dataset.prix;
        selectedDiv.style.display = 'block';
        dropdown.style.display = 'none';
      });
    });
  });

  document.addEventListener('click', (e) => {
    if (!document.getElementById('produitResults').contains(e.target)) dropdown.style.display = 'none';
  });
</script>
