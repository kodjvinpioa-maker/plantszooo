<% layout('layout') -%>
<% var currentPath = '/stock'; %>

<h1 class="page-title"><i class="fas fa-box"></i> Gestion du stock</h1>

<!-- Entrée stock -->
<div class="card" style="max-width:600px;">
  <div class="card-header">
    <span class="card-title"><i class="fas fa-arrow-down" style="color:var(--vert-succes);"></i> Entrée de stock</span>
  </div>
  <form method="POST" action="/stock/entree">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-group">
      <label class="form-label">Produit *</label>
      <select name="produit_id" class="form-select" required>
        <option value="">Choisir un produit...</option>
        <% produits.forEach(p => { %>
        <option value="<%= p.id %>"><%= p.nom %> (<%= p.reference %>) — Stock: <%= p.stock %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Quantité *</label>
        <input type="number" name="quantite" class="form-control" min="1" required>
      </div>
      <div class="form-group">
        <label class="form-label">Prix achat unitaire (FCFA)</label>
        <input type="number" name="prix_achat_unitaire" class="form-control" min="0" step="1">
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">Date</label>
      <input type="datetime-local" name="date_mouvement" class="form-control">
    </div>
    <div class="form-group">
      <label class="form-label">Commentaire</label>
      <textarea name="commentaire" class="form-control" rows="2"></textarea>
    </div>
    <div class="form-check mb-2">
      <input type="checkbox" name="payer_caisse" id="payerCaisse" value="1">
      <label for="payerCaisse">Payer depuis la caisse (débit automatique)</label>
    </div>
    <button type="submit" class="btn btn-success btn-block"><i class="fas fa-plus-circle"></i> Enregistrer l'entrée</button>
  </form>
</div>

<!-- Sortie stock -->
<div class="card" style="max-width:600px;margin-top:1.5rem;">
  <div class="card-header">
    <span class="card-title"><i class="fas fa-arrow-up" style="color:var(--rouge-alerte);"></i> Sortie de stock</span>
  </div>
  <form method="POST" action="/stock/sortie">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-group">
      <label class="form-label">Produit *</label>
      <select name="produit_id" class="form-select" required>
        <option value="">Choisir un produit...</option>
        <% produits.forEach(p => { %>
        <option value="<%= p.id %>"><%= p.nom %> (<%= p.reference %>) — Stock: <%= p.stock %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Quantité *</label>
        <input type="number" name="quantite" class="form-control" min="1" required>
      </div>
      <div class="form-group">
        <label class="form-label">Motif *</label>
        <select name="motif" class="form-select" required>
          <option value="">Choisir...</option>
          <option value="Casse">Casse</option>
          <option value="Défectueux">Défectueux</option>
          <option value="Périmé">Périmé</option>
          <option value="Autre">Autre</option>
        </select>
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">Date</label>
      <input type="datetime-local" name="date_mouvement" class="form-control">
    </div>
    <div class="form-group">
      <label class="form-label">Commentaire</label>
      <textarea name="commentaire" class="form-control" rows="2"></textarea>
    </div>
    <button type="submit" class="btn btn-danger btn-block"><i class="fas fa-minus-circle"></i> Enregistrer la sortie</button>
  </form>
</div>
