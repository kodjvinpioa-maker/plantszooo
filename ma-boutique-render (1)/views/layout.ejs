<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MaBoutique - Gestion de Stock & Caisse</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <% if (typeof hideNav === 'undefined' || !hideNav) { %>
  <header class="app-header">
    <div class="header-inner">
      <a href="/dashboard" class="logo">
        <span class="logo-icon">🌿</span>
        <span>MaBoutique</span>
      </a>
      <nav class="header-nav" id="headerNav">
        <a href="/dashboard" class="<%= currentPath === '/dashboard' ? 'active' : '' %>"><i class="fas fa-leaf"></i> Tableau</a>
        <a href="/vente" class="<%= currentPath === '/vente' ? 'active' : '' %>"><i class="fas fa-coins"></i> Vente</a>
        <a href="/stock" class="<%= currentPath === '/stock' ? 'active' : '' %>"><i class="fas fa-box"></i> Stock</a>
        <a href="/caisse" class="<%= currentPath === '/caisse' ? 'active' : '' %>"><i class="fas fa-wallet"></i> Caisse</a>
        <a href="/historique-stock" class="<%= currentPath === '/historique-stock' ? 'active' : '' %>"><i class="fas fa-history"></i> Historique</a>
        <a href="/chatbot" class="<%= currentPath === '/chatbot' ? 'active' : '' %>"><i class="fas fa-seedling"></i> Assistant</a>
        <% if (user && user.role === 'admin') { %>
        <a href="/produits" class="<%= currentPath === '/produits' ? 'active' : '' %>"><i class="fas fa-boxes"></i> Produits</a>
        <a href="/rapports" class="<%= currentPath === '/rapports' ? 'active' : '' %>"><i class="fas fa-chart-line"></i> Rapports</a>
        <a href="/utilisateurs" class="<%= currentPath === '/utilisateurs' ? 'active' : '' %>"><i class="fas fa-users"></i> Utilisateurs</a>
        <a href="/journal" class="<%= currentPath === '/journal' ? 'active' : '' %>"><i class="fas fa-clipboard-list"></i> Journal</a>
        <% } %>
        <a href="/logout"><i class="fas fa-sign-out-alt"></i> Déconnexion</a>
      </nav>
      <div style="display:flex;align-items:center;gap:0.8rem;">
        <span class="user-info"><i class="fas fa-user-circle"></i> <%= user ? user.email : '' %></span>
        <button class="burger-btn" onclick="document.getElementById('headerNav').classList.toggle('open')">
          <i class="fas fa-bars"></i>
        </button>
      </div>
    </div>
  </header>

  <!-- Barre mobile fixe en bas -->
  <nav class="mobile-nav">
    <div class="mobile-nav-inner">
      <a href="/vente" class="<%= currentPath === '/vente' ? 'active' : '' %>">
        <i class="fas fa-coins"></i><span>Vente</span>
      </a>
      <a href="/stock" class="<%= currentPath === '/stock' ? 'active' : '' %>">
        <i class="fas fa-box"></i><span>Stock</span>
      </a>
      <a href="/caisse" class="<%= currentPath === '/caisse' ? 'active' : '' %>">
        <i class="fas fa-wallet"></i><span>Caisse</span>
      </a>
      <a href="/dashboard" class="<%= currentPath === '/dashboard' ? 'active' : '' %>">
        <i class="fas fa-bars"></i><span>Menu</span>
      </a>
    </div>
  </nav>
  <% } %>

  <main class="main-container">
    <%- body %>
  </main>

  <!-- Toast container -->
  <div class="toast-container" id="toastContainer"></div>

  <script>
    // Flash messages auto-toast
    <% if (flash) { %>
    showToast(`<%= flash.message %>`, '<%= flash.type %>');
    <% } %>

    function showToast(message, type = 'success') {
      const container = document.getElementById('toastContainer');
      const toast = document.createElement('div');
      toast.className = 'toast';
      const icon = type === 'success' ? '🌿' : '⚠️';
      toast.innerHTML = `<i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i> <span>${message}</span>`;
      container.appendChild(toast);
      setTimeout(() => {
        toast.classList.add('hiding');
        setTimeout(() => toast.remove(), 300);
      }, 4000);
    }

    // Fermer menu burger au clic extérieur
    document.addEventListener('click', (e) => {
      const nav = document.getElementById('headerNav');
      const btn = document.querySelector('.burger-btn');
      if (nav && btn && !nav.contains(e.target) && !btn.contains(e.target)) {
        nav.classList.remove('open');
      }
    });
  </script>
</body>
</html>
