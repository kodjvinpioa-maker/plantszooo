<% layout('layout') -%>
<% var currentPath = '/historique-stock'; %>

<h1 class="page-title"><i class="fas fa-history"></i> Historique des mouvements de stock</h1>

<div class="card">
  <div class="table-wrapper">
    <table class="table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Type</th>
          <th>Produit</th>
          <th>Qté</th>
          <th>Prix effectif</th>
          <th>Commentaire</th>
          <th>Utilisateur</th>
          <% if (user.role === 'admin') { %><th>Action</th><% } %>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(r => { %>
        <tr>
          <td><%= new Date(r.date_mouvement).toLocaleString('fr-FR') %></td>
          <td>
            <span class="badge badge-<%= r.type === 'vente' ? 'info' : (r.type === 'entree' ? 'success' : 'danger') %>">
              <i class="fas fa-<%= r.type === 'vente' ? 'shopping-cart' : (r.type === 'entree' ? 'arrow-down' : 'arrow-up') %>"></i>
              <%= r.type %>
            </span>
          </td>
          <td><strong><%= r.produit_nom || '—' %></strong></td>
          <td><%= r.quantite %></td>
          <td><%= r.prix_vente_effectif ? r.prix_vente_effectif.toLocaleString('fr-FR') + ' FCFA' : '—' %></td>
          <td><%= r.commentaire || '—' %></td>
          <td><%= r.user_email || '—' %></td>
          <% if (user.role === 'admin') { %>
          <td>
            <% if (r.type === 'vente') { %>
            <form method="POST" action="/ventes/<%= r.id %>/annuler" style="display:inline;" onsubmit="return confirm('Annuler cette vente ? Le stock et la caisse seront ajustés.');">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-undo"></i> Annuler</button>
            </form>
            <% } else { %>
            <span style="color:#aaa;font-size:0.85rem;">—</span>
            <% } %>
          </td>
          <% } %>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% if (rows.length === 0) { %>
    <p class="text-center" style="color:#777;padding:2rem;">Aucun mouvement enregistré.</p>
  <% } %>
</div>
